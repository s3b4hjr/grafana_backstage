# Grafana connection for the Backstage Grafana plugin.
# Copy to `grafana.env` (which is gitignored — never commit the real token):
#
#   cp grafana.env.example grafana.env
#
# Easiest: from the repo root just run `make backstage-token`, which creates a
# Grafana service account + token and writes grafana.env for you.
#
# Manual: Grafana → Administration → Service accounts → add one (role: Viewer)
# → Add token, then paste it below.

# Where the stack's Grafana is reachable from the Backstage backend.
#   • Backstage on the Docker host        -> http://localhost:3000
#   • Backstage in a container on the net -> http://grafana:3000
GRAFANA_URL=http://localhost:3000

# Grafana service-account token (Viewer is enough). Looks like: glsa_xxxxxxxx...
GRAFANA_TOKEN=glsa_replace_me
