# ==========================================================================
# Observability Stack — environment configuration
# Copy to ".env" and adjust. Everything here is overridable per environment.
#   cp .env.example .env
# ==========================================================================

# --- Compose ---------------------------------------------------------------
COMPOSE_PROJECT_NAME=observability
TZ=UTC

# --- Image versions (pinned; bump deliberately) ----------------------------
GRAFANA_VERSION=grafana/grafana:13.0.2
PROMETHEUS_VERSION=prom/prometheus:v3.12.0
ALERTMANAGER_VERSION=prom/alertmanager:v0.33.0
LOKI_VERSION=grafana/loki:3.7.3
TEMPO_VERSION=grafana/tempo:2.10.7
ALLOY_VERSION=grafana/alloy:v1.17.0
NODE_EXPORTER_VERSION=prom/node-exporter:v1.11.1
CADVISOR_VERSION=gcr.io/cadvisor/cadvisor:v0.55.1
BLACKBOX_VERSION=prom/blackbox-exporter:v0.28.0

# --- Published host ports (left side of host:container mapping) ------------
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
LOKI_PORT=3100
TEMPO_PORT=3200
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
NODE_EXPORTER_PORT=9100
CADVISOR_PORT=8080
BLACKBOX_PORT=9115
ALLOY_PORT=12345

# --- Grafana ---------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Public root URL when behind a reverse proxy (e.g. https://grafana.example.com)
GRAFANA_ROOT_URL=
# Comma-separated plugin list, e.g. grafana-piechart-panel,grafana-clock-panel
GRAFANA_INSTALL_PLUGINS=
GRAFANA_LOG_LEVEL=info

# --- Email for alert notifications (optional; used by Grafana alerting) -----
# Leave disabled to use Slack/Discord/webhook contact points instead.
GF_SMTP_ENABLED=false
GF_SMTP_HOST=smtp.example.com:587
GF_SMTP_USER=
GF_SMTP_PASSWORD=
GF_SMTP_FROM_ADDRESS=grafana@grafana.localhost
GF_SMTP_FROM_NAME=Grafana Alerts

# --- Retention -------------------------------------------------------------
PROMETHEUS_RETENTION_TIME=15d
# 0 = unlimited; otherwise e.g. 10GB
PROMETHEUS_RETENTION_SIZE=0
# Loki/Tempo durations use Go duration syntax (h/m/s only — no "d")
LOKI_RETENTION_PERIOD=168h
TEMPO_RETENTION=48h
