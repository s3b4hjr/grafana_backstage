# Drop these env vars into ANY OpenTelemetry-instrumented app (Node, Python, Go,
# Java, .NET, ...) and it will send traces (and OTLP metrics/logs) to this stack
# via the Alloy gateway. No app code changes — the OTel SDK reads these.
#
#   • From the Docker HOST:                 use localhost
#   • From a CONTAINER on `observability`:  use   alloy   instead of localhost

OTEL_SERVICE_NAME=my-app
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_RESOURCE_ATTRIBUTES=service.namespace=demo,deployment.environment=local

# gRPC alternative (port 4317):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
